{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "model": "github-copilot/claude-sonnet-4.6",
      "ultrawork": {}
    },
    "sisyphus-junior": {
      "model": "github-copilot/claude-haiku-4.5",
      "variant": "low"
    },
    "prometheus": {
      "model": "github-copilot/claude-opus-4.8",
      "variant": "medium"
    },
    "atlas": {
      "model": "github-copilot/claude-sonnet-4.6",
      "disable": true
    },
    "hephaestus": {
      "model": "github-copilot/gpt-5.4",
      "variant": "medium"
    },
    "metis": {
      "model": "github-copilot/claude-sonnet-4.6",
      "variant": "high"
    },
    "momus": {
      "model": "github-copilot/claude-sonnet-4.6",
      "variant": "high"
    },
    "oracle": {
      "model": "github-copilot/claude-sonnet-4.6",
      "variant": "medium"
    },
    "librarian": {
      "model": "github-copilot/gemini-3-flash"
    },
    "explore": {
      "model": "github-copilot/gpt-5-mini"
    },
    "multimodal-looker": {
      "model": "github-copilot/gemini-3-flash"
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "github-copilot/gemini-3.1-pro",
      "variant": "medium"
    },
    "artistry": {
      "model": "github-copilot/gemini-3.1-pro",
      "variant": "medium"
    },
    "ultrabrain": {
      "model": "github-copilot/gpt-5.3-codex",
      "variant": "high"
    },
    "deep": {
      "model": "github-copilot/claude-sonnet-4.6",
      "variant": "high"
    },
    "writing": {
      "model": "github-copilot/claude-sonnet-4.6"
    },
    "quick": {
      "model": "github-copilot/gpt-5-mini"
    },
    "unspecified-low": {
      "model": "github-copilot/gpt-5-mini"
    },
    "unspecified-high": {
      "model": "github-copilot/claude-sonnet-4.6"
    }
  },
  "background_task": {
    "providerConcurrency": {
      "github-copilot": 3
    },
    "modelConcurrency": {
      "github-copilot/claude-sonnet-4.6": 2,
      "github-copilot/gemini-3.1-pro": 2
    }
  },
  "experimental": {
    "aggressive_truncation": false,
    "task_system": true
  },
  "git_master": {
    "git_env_prefix": "",
    "commit_footer": "",
    "include_co_authored_by": false
  }
}
