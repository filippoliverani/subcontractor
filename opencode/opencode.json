{
  "$schema": "https://opencode.ai/config.json",
  "model": "copilot/claude-opus-4.6",
  "small_model": "copilot/claude-sonnet-4.6",
  "autoupdate": true,
  "plugin": [
    "oh-my-openagent@latest"
  ],
  "instructions": [
    "~/.dotfiles/MYAGENTS.md",
    "./docs/**/*"
  ],
  "formatter": {
    "rubocop": {
      "command": [
        "bundle",
        "exec",
        "rubocop",
        "-A",
        "$FILE"
      ],
      "extensions": [
        ".rb",
        ".rake"
      ]
    },
    "erb-formatter": {
      "command": [
        "bundle",
        "exec",
        "erb-formatter",
        "$FILE",
        "--write"
      ],
      "extensions": [
        ".html.erb"
      ]
    },
    "eslint": {
      "command": [
        "yarn",
        "run",
        "lint-javascript",
        "--fix",
        "$FILE",
        "--ignore-pattern",
        "app/assets/builds"
      ],
      "extensions": [
        ".js"
      ]
    },
    "stylelint": {
      "command": [
        "yarn",
        "run",
        "lint-scss",
        "--fix",
        "$FILE"
      ],
      "extensions": [
        ".scss"
      ]
    }
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "tmp/**",
      ".git/**",
      "public/assets/**",
      "public/packs/**",
      "vendor/bundle/**",
      "coverage/**",
      "log/**",
      "app/assets/builds/**",
      "spec/cassettes/**"
    ]
  },
  "permission": {
    "bash": {
      "*": "ask",
      "sudo *": "deny",
      "rm -rf *": "ask",
      "cat *": "allow",
      "diff *": "allow",
      "ls *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "find *": "allow",
      "wc *": "allow",
      "echo *": "allow",
      "xargs *": "allow",
      "sort *": "allow",
      "true *": "allow",
      "read *": "allow",
      "sed *": "allow",
      "date *": "allow",
      "mkdir *": "allow",
      "gem show *": "allow",
      "bundle install *": "allow",
      "bundle show *": "allow",
      "bundle exec rspec *": "allow",
      "bundle exec rubocop *": "allow",
      "bundle exec rails *": "allow",
      "bin/rails *": "allow",
      "bin/rake *": "allow",
      "bin/rspec *": "allow",
      "bin/rubocop *": "allow",
      "yarn build *": "allow",
      "yarn install *": "allow",
      "gh *": "allow",
      "gh *delete*": "deny",
      "git *": "allow",
      "git rm *": "deny"
    },
    "doom_loop": "ask"
  },
  "lsp": {
    "ruby-lsp": {
      "command": [
        "ruby-lsp",
        "stdio"
      ],
      "extensions": [
        ".erb.html"
      ]
    },
    "solargraph": {
      "command": [
        "solargraph",
        "stdio"
      ],
      "extensions": [
        ".rb",
        ".rake",
        ".gemspec",
        ".ru"
      ]
    }
  },
  "snapshot": true,
  "mcp": {
    "rails": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-remote",
        "https://dev.frame.work:3000/tidewave/mcp"
      ],
      "environment": {
        "NODE_EXTRA_CA_CERTS": "config/certs/rootCA.pem"
      },
      "enabled": true
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp",
      "headers": {
        "Authorization": "Bearer {env:GITHUB_PERSONAL_ACCESS_TOKEN}"
      },
      "enabled": true
    },
    "jira": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/sse",
      "oauth": {},
      "enabled": true
    },
    "datadog": {
      "type": "remote",
      "url": "https://mcp.datadoghq.com/api/unstable/mcp-server/mcp?toolsets=core,apm",
      "oauth": {},
      "enabled": true
    }
  },
  "experimental": {
    "lsp_diagnostics_timeout_ms": 30000
  }
}
