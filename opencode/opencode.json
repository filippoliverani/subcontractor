{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/claude-sonnet-4.6",
  "small_model": "github-copilot/gpt-5.4-nano",
  "autoupdate": true,
  "enabled_providers": [
    "github-copilot"
  ],
  "plugin": [
    "envsitter-guard@latest",
    "opencode-background-agents@latest",
    "opencode-handoff@latest",
    "opencode-pty@latest",
    "opencode-websearch@latest",
    "openslimedit@latest"
  ],
  "instructions": [
    "~/.subcontractor/AGENTS.md",
    "./docs/coding_conventions/*.md"
  ],
  "agent": {
    "plan": {
      "model": "github-copilot/claude-opus-4.8"
    },
    "build": {
      "model": "github-copilot/claude-sonnet-4.6"
    },
    "general": {
      "model": "github-copilot/claude-haiku-4.5"
    },
    "explore": {
      "model": "github-copilot/gpt-5-mini"
    },
    "scout": {
      "model": "github-copilot/gpt-5-mini"
    },
    "title": {
      "model": "github-copilot/gpt-5.4-nano"
    },
    "summary": {
      "model": "github-copilot/gpt-5-mini"
    },
    "compaction": {
      "model": "github-copilot/gpt-5-mini"
    },
    "review": {
      "model": "github-copilot/claude-sonnet-4.6"
    },
    "write": {
      "model": "github-copilot/gpt-5-mini"
    }
  },
  "formatter": {
    "rubocop": {
      "command": [
        "bundle",
        "exec",
        "rubocop",
        "-A",
        "$FILE"
      ],
      "extensions": [
        ".rb",
        ".rake"
      ]
    },
    "erb-formatter": {
      "command": [
        "bundle",
        "exec",
        "erb-formatter",
        "$FILE",
        "--write"
      ],
      "extensions": [
        ".html.erb"
      ]
    },
    "eslint": {
      "command": [
        "yarn",
        "run",
        "lint-javascript",
        "--fix",
        "$FILE",
        "--ignore-pattern",
        "app/assets/builds"
      ],
      "extensions": [
        ".js"
      ]
    },
    "stylelint": {
      "command": [
        "yarn",
        "run",
        "lint-scss",
        "--fix",
        "$FILE"
      ],
      "extensions": [
        ".scss"
      ]
    }
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "tmp/**",
      ".git/**",
      "public/assets/**",
      "public/packs/**",
      "vendor/bundle/**",
      "coverage/**",
      "log/**",
      "app/assets/builds/**",
      "spec/cassettes/**"
    ]
  },
  "permission": {
    "external_directory": {
      "~/.subcontractor/**": "allow",
      "/opt/homebrew/lib/ruby/gems/**" : "allow",
      "*": "ask"
    },
    "bash": {
      "*": "ask",
      "sudo *": "deny",
      "rm -rf *": "ask",
      "cat *": "allow",
      "diff *": "allow",
      "ls *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "find *": "allow",
      "wc *": "allow",
      "echo *": "allow",
      "xargs *": "allow",
      "sort *": "allow",
      "true *": "allow",
      "read *": "allow",
      "sed *": "allow",
      "date *": "allow",
      "mkdir *": "allow",
      "gem show *": "allow",
      "bundle install *": "allow",
      "bundle show *": "allow",
      "bundle exec rspec *": "allow",
      "bundle exec rubocop *": "allow",
      "bundle exec rails *": "allow",
      "bin/rails *": "allow",
      "bin/rake *": "allow",
      "bin/rspec *": "allow",
      "bin/rubocop *": "allow",
      "yarn build *": "allow",
      "yarn install *": "allow",
      "gh *": "allow",
      "gh *delete*": "deny",
      "git *": "allow",
      "git rm *": "deny"
    },
    "doom_loop": "ask"
  },
  "lsp": {
    "ruby-lsp": {
      "command": [
        "ruby-lsp",
        "stdio"
      ],
      "extensions": [
        ".rb",
        ".rake",
        ".gemspec",
        ".ru",
        ".html.erb"
      ]
    },
  },
  "snapshot": true,
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 5000
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp@latest"]
    },
    "rails": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-remote",
        "https://dev.frame.work:3000/tidewave/mcp"
      ],
      "environment": {
        "NODE_EXTRA_CA_CERTS": "config/certs/rootCA.pem"
      },
      "enabled": false
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp",
      "headers": {
        "Authorization": "Bearer {env:GITHUB_PERSONAL_ACCESS_TOKEN}"
      },
      "enabled": true
    },
    "jira": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/sse",
      "oauth": {},
      "enabled": false
    },
    "datadog": {
      "type": "remote",
      "url": "https://mcp.datadoghq.com/api/unstable/mcp-server/mcp?toolsets=core,apm",
      "oauth": {},
      "enabled": false
    },
    "cloudflare": {
      "type": "remote",
      "url": "https://mcp.cloudflare.com/mcp",
      "oauth": {},
      "enabled": false
    },
    "heroku": {
      "type": "local",
      "command": ["npx", "-y", "@heroku/mcp-server"],
      "environment": {
        "HEROKU_API_KEY": "{env:HEROKU_API_KEY}"
      },
      "enabled": false
    }
  }
}
